# API Configuration
PORT=8000
HOST=0.0.0.0

# Database
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/apexiq

# Celery / Redis
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0

# Intelligence Weights
WEIGHT_SIMULATION=0.25
WEIGHT_HISTORY=0.20
WEIGHT_MEMORY=0.20
WEIGHT_ML=0.35

# API Keys (set these in your local .env, never commit secrets)
# GROQ_API_KEY=gsk_your_groq_key_here
# APEXIQ_API_KEY=your_apexiq_api_key_here

# Frontend
# VITE_API_URL=http://127.0.0.1:8000
