# ── APEXiq Environment Variables ────────────────────────────────
# Copy this file to .env and fill in your values
# Never commit .env to version control

# ── Backend ─────────────────────────────────────────────────────
PORT=8000
HOST=0.0.0.0
LOG_LEVEL=info
ENVIRONMENT=development

# ── Database ────────────────────────────────────────────────────
POSTGRES_USER=apexiq
POSTGRES_PASSWORD=apexiq_pass
POSTGRES_DB=apexiq
DATABASE_URL=postgresql+asyncpg://apexiq:apexiq_pass@localhost:5432/apexiq

# ── Redis / Celery ─────────────────────────────────────────────
REDIS_PORT=6379
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0

# ── CORS (comma-separated origins) ─────────────────────────────
CORS_ORIGINS=http://localhost:3000,http://localhost:80

# ── Intelligence Weights ───────────────────────────────────────
WEIGHT_SIMULATION=0.25
WEIGHT_HISTORY=0.20
WEIGHT_MEMORY=0.20
WEIGHT_ML=0.35

# ── API Keys (set these in your local .env, never commit) ─────
# GROQ_API_KEY=gsk_your_groq_key_here
# API_KEY=your_apexiq_api_key_here

# ── Frontend ────────────────────────────────────────────────────
VITE_API_URL=http://127.0.0.1:8000
# VITE_API_KEY=your_apexiq_api_key_here

# ── Docker Ports ────────────────────────────────────────────────
API_PORT=8000
FRONTEND_PORT=3000
NGINX_PORT=80
