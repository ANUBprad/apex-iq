# APEXiq Environment Configuration
# Copy this to .env and fill in your values

# Backend
PORT=8000
HOST=0.0.0.0
LOG_LEVEL=info
CORS_ORIGINS=http://localhost:3000,https://your-frontend.vercel.app

# Database (optional — simulation works without it)
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/apexiq

# Redis (optional — used for caching)
REDIS_URL=redis://localhost:6379/0

# Frontend (for local dev)
VITE_API_URL=http://127.0.0.1:8000
